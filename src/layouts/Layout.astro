---
import { Toaster as Sonner } from "@/components/ui/sonner";
import { TooltipProvider } from "@/components/ui/tooltip";
import HeaderIsland from "@/components/layout/HeaderIsland";
import FooterStatic from "@/components/layout/FooterStatic.astro";
import SplashScreenIsland from "@/components/ui/SplashScreenIsland";
import "@/index.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  image?: string;
  canonicalURL?: string;
  articleSchema?: string;
  ogType?: string;
  articleDate?: string;
  articleAuthor?: string;
  articleSection?: string;
  currentPath?: string;
}

const { 
  title = "Nils Digital Studio", 
  description = "A GenAI Product Manager's portfolio.",
  lang = "en",
  image = "/images/og-default.jpg",
  canonicalURL,
  articleSchema,
  ogType = "website",
  articleDate,
  articleAuthor,
  articleSection,
  currentPath
} = Astro.props;

// For generating full image URLs if a relative path is provided
const socialImageUrl = new URL(
  image.startsWith('/') ? image : image, 
  Astro.site || 'https://nilsliu.dev/'
).href;
const htmlLang = lang === "zh" ? "zh-TW" : lang;

const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const pathWithoutBase = Astro.url.pathname.startsWith(basePath) 
  ? Astro.url.pathname.slice(basePath.length) 
  : Astro.url.pathname;
const pathWithoutLang = pathWithoutBase.replace(/^\/?(zh|en|de)\/?/, '/');
const cleanPath = (p: string) => p.replace(/\/\/+/g, '/');

const hreflangZh = new URL(cleanPath(`${basePath}/zh${pathWithoutLang}`), Astro.site || 'https://nilsliu.dev/').href;
const hreflangEn = new URL(cleanPath(`${basePath}/en${pathWithoutLang}`), Astro.site || 'https://nilsliu.dev/').href;
const hreflangDe = new URL(cleanPath(`${basePath}/de${pathWithoutLang}`), Astro.site || 'https://nilsliu.dev/').href;

// JSON-LD Person & ProfessionalService schema
const personDesc = lang === 'en'
  ? 'Taiwan-based GenAI architect & consultant. Led CathayGPT. 6 AI patents. Specializing in AI Agents, RAG, and LLM enterprise deployment.'
  : lang === 'de'
  ? 'GenAI-Architekt und Berater aus Taiwan. Leitung von CathayGPT. 6 AI-Patente. Spezialisiert auf AI Agents, RAG und LLM-Enterprise-Deployment.'
  : '台灣金融業 GenAI 架構師與顧問。主導 CathayGPT 等生產級 AI 系統，擁有 6 項 AI 專利。';

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://nilsliu.dev/#person",
  "name": "劉岦崱 Nils Liu",
  "alternateName": "Nils Liu",
  "url": "https://nilsliu.dev",
  "image": "https://nilsliu.dev/nils-profile.jpg",
  "jobTitle": "GenAI Solution Architect",
  "worksFor": {
    "@type": "Organization",
    "name": "Cathay Financial Holdings"
  },
  "description": personDesc,
  "knowsAbout": ["GenAI", "AI Agent", "RAG", "LLM", "Prompt Engineering", "Enterprise AI"],
  "sameAs": [
    "https://www.linkedin.com/in/nilsliu/"
  ]
});

const serviceDesc = lang === 'en'
  ? 'GenAI consulting, rapid prototyping, and enterprise team training. Specializing in AI Agent, RAG, and LLM enterprise deployment.'
  : lang === 'de'
  ? 'GenAI-Beratung, schnelles Prototyping und Enterprise-Team-Training. Spezialisiert auf AI Agent, RAG und LLM-Enterprise-Deployment.'
  : 'GenAI 顧問諮詢、快速原型開發與企業團隊培訓服務。專注 AI Agent、RAG、LLM 企業落地。';

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://nilsliu.dev/#service",
  "name": "Nils Digital Studio",
  "url": "https://nilsliu.dev",
  "description": serviceDesc,
  "provider": {
    "@type": "Person",
    "name": "劉岦崱 Nils Liu"
  },
  "areaServed": {
    "@type": "Country",
    "name": "TW"
  },
  "email": "wulingteen@gmail.com",
  "serviceType": ["AI Consulting", "GenAI Architecture", "Team Training", "Rapid Prototyping"]
});
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL || new URL(Astro.url.pathname, Astro.site || 'https://nilsliu.dev/').href} />

    <!-- Hreflang Tags for Multi-language SEO -->
    <link rel="alternate" hreflang="zh-TW" href={hreflangZh} />
    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="de" href={hreflangDe} />
    <link rel="alternate" hreflang="x-default" href={hreflangEn} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL || Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:site_name" content="Nils Digital Studio" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_TW' : lang === 'de' ? 'de_DE' : 'en_US'} />
    {lang !== 'en' && <meta property="og:locale:alternate" content="en_US" />}
    {lang !== 'zh' && <meta property="og:locale:alternate" content="zh_TW" />}
    {lang !== 'de' && <meta property="og:locale:alternate" content="de_DE" />}
    {articleDate && <meta property="article:published_time" content={articleDate} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}
    {articleSection && <meta property="article:section" content={articleSection} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@wulingten" />
    <meta name="twitter:creator" content="@wulingten" />
    <meta name="twitter:url" content={canonicalURL || Astro.url.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <!-- Article JSON-LD Schema -->
    {articleSchema && <script type="application/ld+json" set:html={articleSchema} />}

    <!-- Person & Service JSON-LD Schema -->
    <script type="application/ld+json" set:html={personSchema} />
    <script type="application/ld+json" set:html={serviceSchema} />

    <!-- Dark Mode Sync (Taiwan Time) -->
    <script is:inline>
      (function() {
        const now = new Date();
        const taiwanHour = (now.getUTCHours() + 8) % 24;
        if (taiwanHour >= 18 || taiwanHour < 6) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-background text-foreground antialiased min-h-screen flex flex-col">
    <TooltipProvider client:load>
      <Sonner client:load />

      <!-- Splash Screen Island handles session storage logic client-side -->
      <SplashScreenIsland client:load />

      <HeaderIsland client:load lang={lang} currentPath={currentPath || `/${lang}/`} />
      
      <main class="flex-1 pt-16">
        <slot />
      </main>

      <FooterStatic lang={lang} />
    </TooltipProvider>
  </body>
</html>
