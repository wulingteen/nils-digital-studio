---
import { Toaster as Sonner } from "@/components/ui/sonner";
import { TooltipProvider } from "@/components/ui/tooltip";
import HeaderIsland from "@/components/layout/HeaderIsland";
import FooterStatic from "@/components/layout/FooterStatic.astro";
import SplashScreenIsland from "@/components/ui/SplashScreenIsland";
import "@/index.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  image?: string;
  canonicalURL?: string;
  articleSchema?: string;
}

const { 
  title = "Nils Digital Studio", 
  description = "A GenAI Product Manager's portfolio.",
  lang = "en",
  image = "/images/og-default.png",
  canonicalURL,
  articleSchema
} = Astro.props;

// For generating full image URLs if a relative path is provided
const socialImageUrl = new URL(
  image.startsWith('/') ? image : image, 
  Astro.site || 'https://nils-digital-studio.vercel.app/'
).href;
const htmlLang = lang === "zh" ? "zh-TW" : lang;

const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const pathWithoutBase = Astro.url.pathname.startsWith(basePath) 
  ? Astro.url.pathname.slice(basePath.length) 
  : Astro.url.pathname;
const pathWithoutLang = pathWithoutBase.replace(/^\/?(zh|en|de)\/?/, '/');
const cleanPath = (p: string) => p.replace(/\/\/+/g, '/');

const hreflangZh = new URL(cleanPath(`${basePath}/zh${pathWithoutLang}`), Astro.site || 'https://nils-digital-studio.vercel.app/').href;
const hreflangEn = new URL(cleanPath(`${basePath}/en${pathWithoutLang}`), Astro.site || 'https://nils-digital-studio.vercel.app/').href;
const hreflangDe = new URL(cleanPath(`${basePath}/de${pathWithoutLang}`), Astro.site || 'https://nils-digital-studio.vercel.app/').href;

// JSON-LD Person & ProfessionalService schema
const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "劉岦崱 Nils Liu",
  "alternateName": "Nils Liu",
  "url": "https://nils-digital-studio.vercel.app",
  "image": "https://nils-digital-studio.vercel.app/nils-profile.png",
  "jobTitle": "GenAI Solution Architect",
  "worksFor": {
    "@type": "Organization",
    "name": "Cathay Financial Holdings"
  },
  "description": "台灣金融業 GenAI 架構師與顧問。主導 CathayGPT 等生產級 AI 系統，擁有 6 項 AI 專利。",
  "knowsAbout": ["GenAI", "AI Agent", "RAG", "LLM", "Prompt Engineering", "Enterprise AI"],
  "sameAs": [
    "https://www.linkedin.com/in/nils-liu/"
  ]
});

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Nils Digital Studio",
  "url": "https://nils-digital-studio.vercel.app",
  "description": "GenAI 顧問諮詢、快速原型開發與企業團隊培訓服務。專注 AI Agent、RAG、LLM 企業落地。",
  "provider": {
    "@type": "Person",
    "name": "劉岦崱 Nils Liu"
  },
  "areaServed": "TW",
  "serviceType": ["AI Consulting", "GenAI Architecture", "Team Training", "Rapid Prototyping"]
});
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL || new URL(Astro.url.pathname, Astro.site || 'https://nils-digital-studio.vercel.app/').href} />

    <script type="application/json" id="astro-debug-variables">
      {JSON.stringify({
        pathname: Astro.url.pathname,
        basePath: basePath,
        pathWithoutBase: pathWithoutBase,
        pathWithoutLang: pathWithoutLang,
        site: Astro.site?.href,
        hreflangZh: hreflangZh
      })}
    </script>

    <!-- Hreflang Tags for Multi-language SEO -->
    <link rel="alternate" hreflang="zh-TW" href={hreflangZh} />
    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="de" href={hreflangDe} />
    <link rel="alternate" hreflang="x-default" href={hreflangEn} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL || Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:site_name" content="Nils Digital Studio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL || Astro.url.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <!-- Article JSON-LD Schema -->
    {articleSchema && <script type="application/ld+json" set:html={articleSchema} />}

    <!-- Person & Service JSON-LD Schema -->
    <script type="application/ld+json" set:html={personSchema} />
    <script type="application/ld+json" set:html={serviceSchema} />

    <!-- Dark Mode Sync (Taiwan Time) -->
    <script is:inline>
      (function() {
        const now = new Date();
        const taiwanHour = (now.getUTCHours() + 8) % 24;
        if (taiwanHour >= 18 || taiwanHour < 6) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-background text-foreground antialiased min-h-screen flex flex-col">
    <TooltipProvider client:load>
      <Sonner client:load />

      <!-- Splash Screen Island handles session storage logic client-side -->
      <SplashScreenIsland client:load />

      <HeaderIsland client:load lang={lang} currentPath={`/${lang}/`} />
      
      <main class="flex-1 pt-16">
        <slot />
      </main>

      <FooterStatic lang={lang} />
    </TooltipProvider>
  </body>
</html>
