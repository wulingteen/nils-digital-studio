---
import Layout from '../../../layouts/Layout.astro';
import { t } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';
import HeaderIsland from '../../../components/layout/HeaderIsland';
import FooterStatic from '../../../components/layout/FooterStatic.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const langs = ['en', 'zh', 'de'];
  
  return langs.flatMap(lang =>
    posts.map(post => ({
      params: { lang, id: post.id },
      props: { post, lang },
    }))
  );
}

const { post, lang } = Astro.props;
const { Content } = await render(post);

const SITE = 'https://wulingteen.github.io/nils-digital-studio';
const BASE = import.meta.env.BASE_URL;
const B = BASE.endsWith('/') ? BASE : BASE + '/';

const displayTitle = lang === 'en' && post.data.titleEn ? post.data.titleEn
  : lang === 'de' && post.data.titleDe ? post.data.titleDe
  : post.data.title;

const displayExcerpt = lang === 'en' && post.data.excerptEn ? post.data.excerptEn
  : lang === 'de' && post.data.excerptDe ? post.data.excerptDe
  : post.data.excerpt;

const pageUrl = `${SITE}/${lang}/insights/${post.id}`;
const ogImage = post.data.coverImage
  ? `${SITE}${post.data.coverImage}`
  : `${SITE}/nils-profile.png`;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/${lang}` },
    { "@type": "ListItem", "position": 2, "name": t(lang, 'nav.insights', 'Insights'), "item": `${SITE}/${lang}/insights` },
    { "@type": "ListItem", "position": 3, "name": displayTitle, "item": pageUrl },
  ]
};

const articleLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": displayTitle,
  "description": displayExcerpt,
  "author": { "@type": "Person", "name": post.data.author },
  "datePublished": post.data.date.toISOString().split('T')[0],
  "url": pageUrl,
  "image": ogImage,
};
---

<Layout
  title={`${displayTitle} | Nils Liu`}
  description={displayExcerpt}
  lang={lang}
  image={ogImage}
  canonicalURL={pageUrl}
  articleSchema={JSON.stringify([breadcrumbLd, articleLd])}
>
  <HeaderIsland lang={lang} currentPath={`/${lang}/insights/${post.id}`} client:load />

  <article class="min-h-screen pb-20 pt-32">
    <div class="container-narrow mx-auto max-w-3xl px-6 md:px-8">
      <a
        href={`${B}${lang}/insights`}
        class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-primary/80 transition-colors hover:text-primary"
      >
        ← {t(lang, 'blog.back_to_insights', 'Back to Insights')}
      </a>

      <header class="mb-12">
        <h1 class="mb-6 text-4xl font-bold leading-tight text-gradient md:text-5xl lg:leading-[1.1]">
          {displayTitle}
        </h1>
        <div class="flex flex-wrap items-center gap-6 text-sm text-muted-foreground border-b border-primary/20 pb-8">
          <span>{post.data.author}</span>
          <time datetime={post.data.date.toISOString().split('T')[0]}>
            {new Date(post.data.date).toLocaleDateString(
              lang === 'de' ? 'de-DE' : lang === 'zh' ? 'zh-TW' : 'en-US',
              { year: 'numeric', month: 'long', day: 'numeric' }
            )}
          </time>
        </div>
      </header>

      {post.data.coverImage && (
        <div class="mb-12 overflow-hidden rounded-2xl border border-primary/20 shadow-lg">
          <img
            src={`${B}${post.data.coverImage.replace(/^\//, '')}`}
            alt={displayTitle}
            loading="eager"
            decoding="async"
            class="w-full h-auto object-cover max-h-[500px]"
          />
        </div>
      )}

      <div class="article-content prose prose-lg max-w-none prose-headings:text-foreground prose-p:text-muted-foreground prose-strong:text-foreground prose-li:text-muted-foreground prose-a:text-primary">
        <Content />
      </div>
    </div>
  </article>
</Layout>
