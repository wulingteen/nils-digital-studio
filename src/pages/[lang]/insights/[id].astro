---
import Layout from '../../../layouts/Layout.astro';
import { t } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';
import HeaderIsland from '../../../components/layout/HeaderIsland';
import FooterStatic from '../../../components/layout/FooterStatic.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const basePosts = allPosts.filter((p: any) => !p.id.endsWith('-en') && !p.id.endsWith('-de'));
  const langs = ['en', 'zh', 'de'];
  
  return langs.flatMap(lang =>
    basePosts.map((post: any) => ({
      params: { lang, id: post.id },
      props: { basePost: post, lang },
    }))
  );
}

const { basePost, lang } = Astro.props as { basePost: any, lang: string };
const allPosts = await getCollection('posts');
const localizedId = lang === 'zh' ? basePost.id : `${basePost.id}-${lang}`;
const localizedPost = allPosts.find((p: any) => p.id === localizedId) || basePost;
const { Content } = await render(localizedPost);

const allPosts = await getCollection('posts');
const currentTags = basePost.data.tags || [];

const relatedPosts = allPosts
  .filter((p: any) => !p.id.endsWith('-en') && !p.id.endsWith('-de') && p.id !== basePost.id)
  .map(p => {
    let score = 0;
    const pTags = p.data.tags || [];
    pTags.forEach(tag => {
      if (currentTags.includes(tag)) score += 1;
    });
    return { post: p, score };
  })
  .sort((a, b) => {
    if (a.score !== b.score) return b.score - a.score;
    return new Date(b.post.data.date).getTime() - new Date(a.post.data.date).getTime();
  })
  .slice(0, 2)
  .map(item => item.post);

function getRelatedTitle(p: any) {
  if (lang === 'en' && p.data.titleEn) return p.data.titleEn;
  if (lang === 'de' && p.data.titleDe) return p.data.titleDe;
  return p.data.title;
}
function getRelatedExcerpt(p: any) {
  if (lang === 'en' && p.data.excerptEn) return p.data.excerptEn;
  if (lang === 'de' && p.data.excerptDe) return p.data.excerptDe;
  return p.data.excerpt;
}

const SITE = 'https://wulingteen.github.io/nils-digital-studio';
const BASE = import.meta.env.BASE_URL;
const B = BASE.endsWith('/') ? BASE : BASE + '/';

const displayTitle = lang === 'en' && basePost.data.titleEn ? basePost.data.titleEn
  : lang === 'de' && basePost.data.titleDe ? basePost.data.titleDe
  : basePost.data.title;

const displayExcerpt = lang === 'en' && basePost.data.excerptEn ? basePost.data.excerptEn
  : lang === 'de' && basePost.data.excerptDe ? basePost.data.excerptDe
  : basePost.data.excerpt;

const pageUrl = `${SITE}/${lang}/insights/${basePost.id}`;
const ogImage = basePost.data.coverImage
  ? `${SITE}${basePost.data.coverImage}`
  : `${SITE}/nils-profile.png`;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE}/${lang}` },
    { "@type": "ListItem", "position": 2, "name": t(lang, 'nav.insights', 'Insights'), "item": `${SITE}/${lang}/insights` },
    { "@type": "ListItem", "position": 3, "name": displayTitle, "item": pageUrl },
  ]
};

const articleLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": displayTitle,
  "description": displayExcerpt,
  "author": { "@type": "Person", "name": basePost.data.author },
  "datePublished": basePost.data.date.toISOString().split('T')[0],
  "url": pageUrl,
  "image": ogImage,
};
---

<Layout
  title={`${displayTitle} | Nils Liu`}
  description={displayExcerpt}
  lang={lang}
  image={ogImage}
  canonicalURL={pageUrl}
  articleSchema={JSON.stringify([breadcrumbLd, articleLd])}
>
  <HeaderIsland lang={lang} currentPath={`/${lang}/insights/${basePost.id}`} client:load />

  <article class="min-h-screen pb-20 pt-32">
    <div class="container-narrow mx-auto max-w-3xl px-6 md:px-8">
      <a
        href={`${B}${lang}/insights`}
        class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-primary/80 transition-colors hover:text-primary"
      >
        ← {t(lang, 'blog.back_to_insights', 'Back to Insights')}
      </a>

      <header class="mb-12">
        <h1 class="mb-6 text-4xl font-bold leading-tight text-gradient md:text-5xl lg:leading-[1.1]">
          {displayTitle}
        </h1>
        <div class="flex flex-wrap items-center gap-6 text-sm text-muted-foreground border-b border-primary/20 pb-8">
          <span>{basePost.data.author}</span>
          <time datetime={basePost.data.date.toISOString().split('T')[0]}>
            {new Date(basePost.data.date).toLocaleDateString(
              lang === 'de' ? 'de-DE' : lang === 'zh' ? 'zh-TW' : 'en-US',
              { year: 'numeric', month: 'long', day: 'numeric' }
            )}
          </time>
        </div>
      </header>

      {basePost.data.coverImage && (
        <div class="relative mb-12 overflow-hidden rounded-2xl border border-primary/20 shadow-lg">
          <img
            src={`${B}${basePost.data.coverImage.replace(/^\//, '')}`}
            alt={displayTitle}
            loading="eager"
            decoding="async"
            class="w-full h-auto object-cover max-h-[500px]"
          />
          {basePost.data.seriesInfo && (
            <div class="absolute top-4 left-4 px-4 py-1.5 bg-white/60 dark:bg-black/50 backdrop-blur-md rounded-full border border-white/30 shadow-sm z-10 flex items-center gap-2 text-sm font-bold text-slate-900 dark:text-slate-100">
              <span class="w-2 h-2 rounded-full bg-blue-600 shadow-[0_0_8px_rgba(37,99,235,0.8)]"></span>
              {lang === 'zh' ? `第 ${basePost.data.seriesInfo.part} 篇：${basePost.data.seriesInfo.name}`
              : lang === 'de' ? `Teil ${basePost.data.seriesInfo.part}: ${basePost.data.seriesInfo.name}`
              : `Part ${basePost.data.seriesInfo.part}: ${basePost.data.seriesInfo.name}`}
            </div>
          )}
        </div>
      )}

      <div class="article-content prose prose-lg max-w-none prose-headings:text-foreground prose-p:text-muted-foreground prose-strong:text-foreground prose-li:text-muted-foreground prose-a:text-primary">
        <Content />
      </div>

      {relatedPosts.length > 0 && (
        <div class="mt-20 border-t border-primary/20 pt-12">
          <h3 class="mb-8 text-2xl font-bold text-foreground">
            {t(lang, 'blog.related_articles', lang === 'zh' ? '延伸閱讀' : lang === 'de' ? 'Weitere Artikel' : 'Related Articles')}
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {relatedPosts.map((rp) => (
              <a 
                href={`${B}${lang}/insights/${rp.id}`}
                class="group block p-6 rounded-2xl bg-secondary/5 hover:bg-secondary/10 border border-primary/5 hover:border-primary/20 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
              >
                <div class="text-xs text-primary/70 mb-2 font-medium">
                  <time datetime={rp.data.date.toISOString().split('T')[0]}>
                    {new Date(rp.data.date).toLocaleDateString(
                      lang === 'de' ? 'de-DE' : lang === 'zh' ? 'zh-TW' : 'en-US',
                      { year: 'numeric', month: 'short', day: 'numeric' }
                    )}
                  </time>
                </div>
                <h4 class="text-lg font-bold text-foreground group-hover:text-primary transition-colors leading-snug mb-3 line-clamp-2">
                  {getRelatedTitle(rp)}
                </h4>
                <p class="text-sm text-muted-foreground line-clamp-2 leading-relaxed">
                  {getRelatedExcerpt(rp)}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

      <NewsletterForm lang={lang} />
    </div>
  </article>
</Layout>
