---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;
const SITE = 'https://nilsliu.dev';

// Import SinglePage as React island
import SinglePage from '../../pages-react/SinglePage';
---

<Layout
  title={t(lang!, 'meta.title', '劉岦崱 Nils Liu | 台灣 GenAI 顧問・AI Agent 架構師')}
  description={t(lang!, 'meta.description', '台灣金融業 GenAI 架構師與顧問。主導 CathayGPT 等生產級 AI 系統，擁有 6 項 AI 專利。專注 AI Agent、RAG、LLM 企業落地，提供顧問諮詢、快速原型與團隊培訓服務。')}
  lang={lang!}
  ogUrl={`${SITE}/${lang}/`}
  canonicalUrl={`${SITE}/${lang}/`}
>
  <SinglePage lang={lang!} client:load />
</Layout>
