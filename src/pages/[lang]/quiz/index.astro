---
import Layout from '../../../layouts/Layout.astro';
import { t } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;
const SITE = 'https://nilsliu.dev';

import AIPMQuizPage from '../../../components/gamification/AIPMQuizPage';

const pageTitle = lang === 'zh' ? 'AI PM 核心知識遊戲 | Nils Liu' 
  : lang === 'de' ? 'AI PM Wissensspiel | Nils Liu' 
  : 'AI PM Knowledge Game | Nils Liu';
const pageDesc = lang === 'zh' ? '20 道情境題，挑戰你的 AI 產品經理核心能力。涵蓋 RAG、Prompt Engineering、AI Agent 架構等實戰主題。'
  : lang === 'de' ? '20 Szenario-Fragen zur Bewertung Ihrer AI-PM-Kernkompetenzen.'
  : '20 scenario-based questions to assess your AI Product Manager core competencies.';
---

<Layout
  title={pageTitle}
  description={pageDesc}
  lang={lang!}
  canonicalURL={`${SITE}/${lang}/quiz/`}
>
  <section class="section-padding min-h-screen pt-32 pb-20">
    <div class="container-narrow px-6 md:px-8 max-w-3xl mx-auto">
      <AIPMQuizPage lang={lang!} client:only="react" />
    </div>
  </section>
</Layout>
