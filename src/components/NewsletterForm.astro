---
import { t } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;

// You can replace this action URL with your specific Substack, Buttondown, or ConvertKit form action later!
const formAction = "#";
---

<div class="mt-16 rounded-[2rem] border border-primary/10 bg-gradient-to-br from-secondary/5 to-background p-8 md:p-12 text-center relative overflow-hidden shadow-lg">
  <div class="absolute inset-0 bg-grid-white/5 bg-[size:20px_20px] pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none -translate-y-1/2 translate-x-1/2"></div>
  
  <div class="relative z-10 max-w-xl mx-auto">
    <h3 class="text-2xl md:text-3xl font-bold text-foreground mb-4">
      {t(lang, 'newsletter.title', 'Get the latest insights')}
    </h3>
    <p class="text-muted-foreground mb-8 text-sm md:text-base leading-relaxed">
      {t(lang, 'newsletter.desc', 'Join the newsletter to receive my latest articles on GenAI, product management, and architecture.')}
    </p>

    <!-- The form points to the external newsletter provider's URL -->
    <form 
      action={formAction} 
      method="post" 
      target="_blank"
      class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto relative group"
    >
      <input 
        type="email" 
        name="email" 
        placeholder={t(lang, 'newsletter.placeholder', 'Your email address')}
        required
        class="flex-1 rounded-full border border-primary/20 bg-background/80 px-6 py-3.5 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary backdrop-blur-sm transition-all"
      />
      <button 
        type="submit"
        class="rounded-full bg-primary px-8 py-3.5 text-sm font-bold text-primary-foreground shadow-lg transition-all duration-300 hover:bg-primary/90 hover:shadow-primary/25 hover:-translate-y-0.5"
      >
        {t(lang, 'newsletter.button', 'Subscribe')}
      </button>
    </form>
    
    <p class="mt-5 text-[11px] text-muted-foreground/60 tracking-wider uppercase font-medium">
      {t(lang, 'newsletter.spam', 'No spam. Unsubscribe anytime.')}
    </p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const forms = document.querySelectorAll('form[action="#"]');
    forms.forEach(form => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        alert('電子報系統即將上線！請先於原始碼 `NewsletterForm.astro` 內設定您的 Substack 或 Buttondown 訂閱網址。\n\n(Newsletter system integration is pending configuration.)');
      });
    });
  });
</script>
